# Optional workspace root for generated data, runs, logs, and reports.
# Defaults to the directory where you run the command.
GRAPHENE_PIPELINE_HOME=

# Optional path to the stitched-ui project root.
# Defaults to ../stitched-ui relative to GRAPHENE_PIPELINE_HOME.
GRAPHENE_WEBSITE_DIR=

# Optional path to the stitched-ui public directory.
# Defaults to $GRAPHENE_WEBSITE_DIR/public.
GRAPHENE_WEBSITE_PUBLIC_DIR=

# Fiji/ImageJ executable. You can also add Fiji to PATH and leave this blank.
FIJI_EXE=
FIJI_PATH=

# Required only for Roboflow detection mode.
ROBOFLOW_API_KEY=
